@model MakeupStore.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<!-- formularul de login centrat -->
<div class="auth-card">
    <h2>Login</h2>

    <!-- formularul de autentificare -->
    <form asp-controller="Account" asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReturnUrl" />

        <!-- afisam erorile de validare -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-error">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <div class="form-group">
            <label asp-for="Email" class="form-label">Email Address</label>
            <input asp-for="Email" class="form-control" placeholder="your@email.com" type="email" />
            <span asp-validation-for="Email" class="validation-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password" class="form-label">Password</label>
            <input asp-for="Password" class="form-control" placeholder="Your password" type="password" />
            <span asp-validation-for="Password" class="validation-error"></span>
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary btn-block">Login</button>
        </div>
    </form>

    <div class="auth-link">
        <p>Don't have an account? <a asp-controller="Account" asp-action="Register">Register here</a></p>
    </div>

    <!-- credentiale pentru testare -->
    <hr>
    <p class="text-muted">Demo accounts:</p>
    <p class="text-muted">Admin: admin@makeup.com / Admin123</p>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
