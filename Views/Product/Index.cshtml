@model MakeupStore.ViewModels.ProductListViewModel
@{
    ViewData["Title"] = "Products";
}

<div class="catalog-layout">

    <!-- sidebar cu filtre -->
    <aside class="filter-sidebar">
        <div class="filter-card">
            <form method="get" asp-controller="Product" asp-action="Index" id="filter-form">

                <h3>Search</h3>
                <div class="form-group">
                    <input type="text"
                           name="searchTerm"
                           value="@Model.SearchTerm"
                           placeholder="Search products..."
                           class="form-control" />
                </div>

                <h3>Category</h3>
                <div class="filter-options">
                    <label class="filter-option">
                        <input type="radio" name="categoryId" value="" @(Model.SelectedCategoryId == null ? "checked" : "") onchange="this.form.submit()" />
                        All Categories
                    </label>
                    @foreach (var category in Model.Categories)
                    {
                        <label class="filter-option">
                            <input type="radio"
                                   name="categoryId"
                                   value="@category.Id"
                                   @(Model.SelectedCategoryId == category.Id ? "checked" : "")
                                   onchange="this.form.submit()" />
                            @category.Name
                        </label>
                    }
                </div>

                <h3 class="mt-3">Price Range</h3>
                <div class="price-range">
                    <div class="form-group">
                        <label class="form-label">Min Price (lei)</label>
                        <input type="number" name="minPrice" value="@Model.MinPrice" min="0" placeholder="0" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Max Price (lei)</label>
                        <input type="number" name="maxPrice" value="@Model.MaxPrice" min="0" placeholder="Any" class="form-control" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-block mt-3">Apply Filters</button>
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline btn-block mt-2">Clear Filters</a>
            </form>
        </div>
    </aside>

    <!-- lista de produse -->
    <div class="catalog-main">
        <!-- header cu titlu si numarul de produse -->
        <div class="catalog-header">
            <h2>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <span>Results for "@Model.SearchTerm"</span>
                }
                else if (Model.SelectedCategoryId.HasValue)
                {
                    var selectedCat = Model.Categories.FirstOrDefault(c => c.Id == Model.SelectedCategoryId);
                    <span>@(selectedCat?.Name ?? "Products")</span>
                }
                else
                {
                    <span>All Products</span>
                }
            </h2>
            <span class="text-muted">@Model.TotalCount product@(Model.TotalCount != 1 ? "s" : "") found</span>
        </div>

        @if (!Model.Products.Any())
        {
            <!-- mesaj daca nu s-au gasit produse -->
            <p>No products found. <a asp-controller="Product" asp-action="Index">View all products</a></p>
        }
        else
        {
            <!-- cardurile de produse -->
            <div class="container-produse">
                @foreach (var product in Model.Products)
                {
                    <div class="card">
                        <!-- imaginea produsului -->
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" alt="@product.Name" style="width:100%; height:160px; object-fit:contain; background:#fff7fb; border-radius:8px; padding:4px;" />
                        }
                        else
                        {
                            <div class="card-img-placeholder">No image</div>
                        }

                        <span class="badge-categorie">@product.CategoryName</span>
                        <h3>@product.Name</h3>
                        <p>@product.Brand</p>

                        @if (!product.IsInStock)
                        {
                            <p style="color: red; font-size: 12px;">Out of Stock</p>
                        }

                        <p class="pret">@product.Price.ToString("0.00") lei</p>

                        <div class="actiuni-card">
                            <a class="btn btn-outline btn-sm" asp-controller="Product" asp-action="Details" asp-route-id="@product.Id">Details</a>

                            @if (product.IsInStock && Context.Session.GetInt32("UserId").HasValue)
                            {
                                <form method="post" asp-controller="Cart" asp-action="AddToCart" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <input type="hidden" name="quantity" value="1" />
                                    <button type="submit" class="btn btn-primary btn-sm">Add to Cart</button>
                                </form>
                            }

                            @if (Context.Session.GetInt32("UserId").HasValue)
                            {
                                @if (product.IsFavorite)
                                {
                                    <form method="post" asp-controller="Favorite" asp-action="Remove" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <input type="hidden" name="returnUrl" value="/Product" />
                                        <button type="submit" class="btn btn-sm" style="background:#f3d7e5; color:#a85d87;">&#9829;</button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-controller="Favorite" asp-action="Add" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <input type="hidden" name="returnUrl" value="/Product" />
                                        <button type="submit" class="btn btn-sm" style="background:#f3d7e5; color:#a85d87;">&#9825;</button>
                                    </form>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
