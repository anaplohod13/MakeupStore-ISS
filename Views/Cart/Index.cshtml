@model MakeupStore.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Shopping Cart";
}

<h2>Shopping Cart</h2>
<p class="text-muted">@Model.ItemCount item@(Model.ItemCount != 1 ? "s" : "") in your cart</p>

@if (Model.IsEmpty)
{
    <!-- cosul este gol -->
    <div class="mesaj-gol">
        <p>Your cart is empty.</p>
        <a class="btn btn-primary" asp-controller="Product" asp-action="Index">Browse Products</a>
    </div>
}
else
{
    <!-- tabelul cu produsele din cos -->
    <table>
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Subtotal</th>
                <th>Remove</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId">@item.ProductName</a>
                        <br>
                        <span class="text-muted">@item.ProductBrand</span>
                    </td>
                    <td>@item.UnitPrice.ToString("0.00") lei</td>
                    <td>
                        <!-- formularul de actualizare cantitate -->
                        <form method="post" asp-controller="Cart" asp-action="UpdateQuantity" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                            <input type="number" name="quantity" value="@item.Quantity" min="1" max="100"
                                   class="quantity-input" onchange="this.form.submit()" />
                        </form>
                    </td>
                    <td>@item.TotalPrice.ToString("0.00") lei</td>
                    <td>
                        <!-- formularul de stergere din cos -->
                        <form method="post" asp-controller="Cart" asp-action="RemoveItem" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Remove this item?')">X</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- rezumatul comenzii -->
    <div class="cart-summary">
        <h3>Order Summary</h3>
        <p>Items: @Model.ItemCount</p>
        <p class="cart-total">Total: lei @Model.GrandTotal.ToString("0.00")</p>
        <a class="btn btn-primary" asp-controller="Order" asp-action="Checkout">Proceed to Checkout</a>
        <a class="btn btn-outline" asp-controller="Product" asp-action="Index" style="margin-left: 10px;">Continue Shopping</a>
    </div>
}
